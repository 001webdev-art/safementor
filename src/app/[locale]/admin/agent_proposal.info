2. 🔧 Queries SQL (todas em um arquivo)
typescript
// /src/lib/queries/dashboard.ts

// 1. MÉTRICAS PRINCIPAIS
export const GET_METRICS = `
  WITH costs AS (
    SELECT 
      COUNT(*) as total_messages,
      SUM(total_cost) as total_cost,
      COUNT(*) FILTER (WHERE alert_level != 'none') as flagged
    FROM chat_messages
    WHERE message_type = 'assistant'
  )
  SELECT 
    (SELECT COUNT(*) FROM profiles) as total_users,
    (SELECT COUNT(*) FROM children) as total_children,
    costs.*,
    (costs.total_cost / NULLIF(costs.total_messages, 0)) as avg_cost
  FROM costs
`

// 2. CUSTO POR PERÍODO (mais usado)
export const GET_COST_BY_PERIOD = `
  SELECT 
    DATE_TRUNC('day', timestamp) as date,
    COUNT(*) as messages,
    SUM(total_cost) as cost,
    SUM(total_tokens) as tokens
  FROM chat_messages
  WHERE message_type = 'assistant'
    AND timestamp >= NOW() - INTERVAL '30 days'
  GROUP BY DATE_TRUNC('day', timestamp)
  ORDER BY date DESC
`

// 3. CRESCIMENTO DE USUÁRIOS
export const GET_USER_GROWTH = `
  SELECT 
    DATE(created_at) as date,
    COUNT(*) as new_users
  FROM profiles
  WHERE created_at >= NOW() - INTERVAL '30 days'
  GROUP BY DATE(created_at)
  ORDER BY date
`

// 4. ALERTAS RECENTES
export const GET_RECENT_ALERTS = `
  SELECT 
    cm.id,
    c.childrenname as child_name,
    cm.alert_level,
    cm.content,
    cm.timestamp,
    cm.user_intent_prob as probability
  FROM chat_messages cm
  JOIN children c ON c.id = cm.child_id
  WHERE cm.alert_level != 'none'
  ORDER BY cm.timestamp DESC
  LIMIT 20
`

// 5. CUSTO POR MODELO
export const GET_COST_BY_MODEL = `
  SELECT 
    model_used,
    COUNT(*) as requests,
    SUM(total_cost) as total_cost,
    AVG(total_cost) as avg_cost,
    SUM(total_tokens) as tokens
  FROM chat_messages
  WHERE message_type = 'assistant'
  GROUP BY model_used
  ORDER BY total_cost DESC
`
3. 🏗️ API Route (único endpoint)
typescript
// /src/app/api/dashboard/route.ts
import { createRouteHandlerClient } from '@supabase/auth-helpers-nextjs'
import { cookies } from 'next/headers'
import { NextResponse } from 'next/server'

export async function GET(request: Request) {
  const { searchParams } = new URL(request.url)
  const period = searchParams.get('period') || '30d'
  
  const supabase = createRouteHandlerClient({ cookies })
  
  try {
    // Executa todas as queries em paralelo
    const [
      metrics,
      costData,
      userGrowth,
      alerts,
      modelCost
    ] = await Promise.all([
      supabase.rpc('get_dashboard_metrics'), // ou raw SQL
      supabase.rpc('get_cost_by_period', { days: parseInt(period) }),
      supabase.rpc('get_user_growth'),
      supabase.rpc('get_recent_alerts'),
      supabase.rpc('get_cost_by_model')
    ])

    return NextResponse.json({
      metrics: metrics.data?.[0] || {},
      costData: costData.data || [],
      userGrowth: userGrowth.data || [],
      alerts: alerts.data || [],
      modelCost: modelCost.data || []
    })
  } catch (error) {
    return NextResponse.json({ error: 'Failed to fetch dashboard data' }, { status: 500 })
  }
}
