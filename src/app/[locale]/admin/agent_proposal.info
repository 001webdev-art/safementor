Otimização de Queries
sql
-- Materialized Views para dados agregados
CREATE MATERIALIZED VIEW dashboard_metrics AS
SELECT 
  DATE_TRUNC('day', timestamp) as day,
  COUNT(*) as total_messages,
  SUM(total_cost) as total_cost,
  COUNT(DISTINCT child_id) as active_children,
  COUNT(*) FILTER (WHERE alert_level != 'none') as flagged_messages
FROM chat_messages
WHERE message_type = 'assistant'
GROUP BY DATE_TRUNC('day', timestamp);

-- Refresh a cada hora
REFRESH MATERIALIZED VIEW CONCURRENTLY dashboard_metrics;
🎯 KPIs Prioritários
KPI	Fórmula	Frequência
Custo Médio por Mensagem	SUM(total_cost) / COUNT(*)	Diário
Custo por Usuário Ativo	SUM(total_cost) / COUNT(DISTINCT child_id)	Semanal
Taxa de Alerta	(flagged_messages / total_messages) * 100	Diário
ROI de Segurança	(alert_detected / total_cost) * 1000	Mensal
Eficiência de Tokens	completion_tokens / prompt_tokens	Por Modelo
Custo por Token	total_cost / total_tokens	Por Modelo
