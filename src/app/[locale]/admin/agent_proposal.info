export function PeriodSelector({ value, onChange }: { value: string; onChange: (v: string) => void }) {
  return (
    <div className="flex gap-2">
      {periods.map(({ label, value: periodValue }) => (
        <Button
          key={periodValue}
          variant={value === periodValue ? 'default' : 'outline'}
          size="sm"
          onClick={() => onChange(periodValue)}
        >
          {label}
        </Button>
      ))}
    </div>
  )
}
