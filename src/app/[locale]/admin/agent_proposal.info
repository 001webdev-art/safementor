2. Gráficos de Custo e Uso
a) Custo por Período (Bar/Line Chart)
sql
-- Query para custo diário
SELECT 
  DATE(timestamp) as date,
  SUM(total_cost) as daily_cost,
  COUNT(*) as message_count,
  AVG(total_cost) as avg_cost,
  SUM(prompt_tokens) as total_prompt_tokens,
  SUM(completion_tokens) as total_completion_tokens,
  SUM(total_tokens) as total_tokens
FROM chat_messages
WHERE message_type = 'assistant'
  AND timestamp >= NOW() - INTERVAL '30 days'
GROUP BY DATE(timestamp)
ORDER BY date DESC;
b) Distribuição por Modelo (Pie/Doughnut Chart)
sql
SELECT 
  model_used,
  COUNT(*) as usage_count,
  SUM(total_cost) as total_cost,
  SUM(total_tokens) as tokens_used,
  AVG(total_cost) as avg_cost_per_request
FROM chat_messages
WHERE message_type = 'assistant'
GROUP BY model_used;
c) Custo Acumulado (Area Chart)
sql
SELECT 
  DATE(timestamp) as date,
  SUM(SUM(total_cost)) OVER (ORDER BY DATE(timestamp)) as cumulative_cost
FROM chat_messages
WHERE message_type = 'assistant'
GROUP BY DATE(timestamp);
3. Métricas de Segurança e Alertas
a) Alertas por Nível (Bar Chart)
sql
SELECT 
  alert_level,
  COUNT(*) as alert_count,
  AVG(user_intent_intensity) as avg_intensity,
  AVG(user_intent_prob) as avg_probability
FROM chat_messages
WHERE alert_level IS NOT NULL 
  AND alert_level != 'none'
GROUP BY alert_level;
b) Mensagens com Flag (Table + Chart)
sql
SELECT 
  alert_level,
  COUNT(*) as count,
  SUM(CASE WHEN user_intent_means THEN 1 ELSE 0 END) as has_means,
  SUM(CASE WHEN user_intent_actionable THEN 1 ELSE 0 END) as is_actionable,
  AVG(user_intent_prob) as avg_prob
FROM chat_messages
WHERE alert_level != 'none'
GROUP BY alert_level;
4. Métricas de Usuários e Engajamento
a) Novos Usuários por Período (Line Chart)
sql
SELECT 
  DATE(created_at) as signup_date,
  COUNT(*) as new_users,
  COUNT(*) FILTER (WHERE is_subscribed = true) as paid_users
FROM profiles
WHERE created_at >= NOW() - INTERVAL '90 days'
GROUP BY DATE(created_at)
ORDER BY signup_date;
b) Distribuição Geográfica (Map/Table)
sql
SELECT 
  address_country as country,
  COUNT(*) as user_count,
  COUNT(DISTINCT c.id) as children_count,
  SUM(cm.total_cost) as total_cost
FROM profiles p
LEFT JOIN children c ON c.parent_id = p.id
LEFT JOIN chat_messages cm ON cm.child_id = c.id
GROUP BY address_country
ORDER BY user_count DESC;
c) Tiers de Assinatura (Pie Chart)
sql
SELECT 
  subscription_tier,
  COUNT(*) as users,
  COUNT(DISTINCT c.id) as children,
  AVG(EXTRACT(DAY FROM NOW() - created_at)) as avg_days_active
FROM profiles p
LEFT JOIN children c ON c.parent_id = p.id
GROUP BY subscription_tier;
5. Tabela Detalhada de Custos
sql
-- Query para tabela principal
SELECT 
  DATE(cm.timestamp) as date,
  p.email as parent_email,
  c.childrenname as child_name,
  COUNT(cm.id) as messages,
  SUM(cm.total_cost) as daily_cost,
  SUM(cm.total_tokens) as tokens,
  cm.model_used,
  COUNT(cm.id) FILTER (WHERE cm.alert_level != 'none') as alerts
FROM chat_messages cm
JOIN children c ON c.id = cm.child_id
JOIN profiles p ON p.id = c.parent_id
WHERE cm.message_type = 'assistant'
GROUP BY date, p.email, c.childrenname, cm.model_used
ORDER BY date DESC, daily_cost DESC;
6. Análise de Tokens e Eficiência
sql
-- Eficiência por modelo
SELECT 
  model_used,
  AVG(total_tokens) as avg_tokens,
  AVG(prompt_tokens) as avg_prompt,
  AVG(completion_tokens) as avg_completion,
  AVG(total_cost) as avg_cost,
  COUNT(*) as total_requests,
  SUM(total_tokens) as total_tokens_used,
  SUM(total_cost) as total_cost
FROM chat_messages
WHERE message_type = 'assistant'
GROUP BY model_used
ORDER BY total_cost DESC;
