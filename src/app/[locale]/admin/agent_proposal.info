2. Custom Hooks para Dados
tsx
// hooks/useDashboardData.ts
export function useDashboardData(filters: DashboardFilters) {
  const [data, setData] = useState<DashboardData>();
  
  useEffect(() => {
    const fetchData = async () => {
      const supabase = createAdminClient();
      
      // Queries paralelas
      const [metrics, costData, userData, alertData, modelData, detailed] = 
        await Promise.all([
          fetchMetrics(supabase, filters),
          fetchCostData(supabase, filters),
          fetchUserData(supabase, filters),
          fetchAlertData(supabase, filters),
          fetchModelData(supabase, filters),
          fetchDetailedData(supabase, filters)
        ]);
      
      setData({ metrics, costData, userData, alertData, modelData, detailed });
    };
    
    fetchData();
  }, [filters]);
  
  return { data, isLoading };
}
