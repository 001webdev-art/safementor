          "detail": "const toggleGroup = (groupId: string) => { const newState = { ...collapsedGroups, [groupId]: !collapsedGroups[groupId] }; setCollapsedGroups(newState); localStorage.setItem('dashboard_collapsed_groups', JSON.stringify(newState)); };",
